BRANDING_DARK_DANGER_BORDER_COLOR=#5a3a3a
BRANDING_DARK_WARNING_BG_COLOR=#3a3520

# ─── [M] Maps ────────────────────────────────────────────────────────
# provider ∈ {google, yandex, stadia}. Matching API key is required.

MAP_PROVIDER=stadia
MAP_DEFAULT_CENTER=4.35,50.85
STADIA_API_KEY=
GOOGLE_MAPS_API_KEY=
YANDEX_MAPS_API_KEY=

# ─── [N] Frontend build-args ─────────────────────────────────────────
# Build-time env vars baked into JS bundles. Changing any of these
# requires `docker compose build --no-cache <app>`.

# Webapp (Next.js — NEXT_PUBLIC_* prefix exposes to browser)
NEXT_PUBLIC_PROJECT_NAME="Apostol CSMS"
NEXT_PUBLIC_OAUTH_CLIENT_ID=
NEXT_PUBLIC_OAUTH_SCOPE=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_API_HOST=
NEXT_PUBLIC_CLOUD_URL=
NEXT_PUBLIC_MAP_PROVIDER=stadia
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
NEXT_PUBLIC_STADIA_API_KEY=
NEXT_PUBLIC_MAP_DEFAULT_CENTER=4.35,50.85
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_NOMINATIM_URL=

# Driver (Vite — currently uses unprefixed vars injected at build)
API_HOST=
API_VERSION=/api/v1
WS_HOST=
USE_DYNAMIC_MANIFEST=0
BRAND_CODE=csms

# Pay (Nuxt — NUXT_PUBLIC_* exposes to browser)
NUXT_API_HOST=http://backend:4977
NUXT_PUBLIC_API_HOST=

# Landing (Nuxt — tag manager + contact form)
NUXT_PUBLIC_GTM_ID=

# ─── [O] Backend runtime tunables ────────────────────────────────────

# Worker processes for the C++ backend (1 per CPU is reasonable).
WORKER_PROCESSES=8

# Edge-triggered + one-shot epoll. ON (default) → 10-20% throughput
# boost on linux 5.6+. OFF for level-triggered fallback.
APOSTOL_EPOLL_ET=ON
