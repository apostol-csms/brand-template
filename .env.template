# ═══════════════════════════════════════════════════════════════════════════
#  Apostol CSMS — brand deployment env
# ═══════════════════════════════════════════════════════════════════════════
#
# This file is the reference template. Do NOT copy it to .env directly —
# install.sh merges this with:
#   1. envs/<env>/.env.template   (per-environment overrides: DOMAIN,
#                                  PLATFORM_VERSION, etc.)
#   2. Secrets provider            (passwords, API keys via
#                                  envs/<env>/secrets/load-from-vault.sh)
# and writes the result to workdir/.env (chmod 600, gitignored).
#
# Mandatory values are marked CHANGE_ME — install.sh refuses to start
# if any of those make it into workdir/.env. Optional values may stay
# empty (feature gated off).
#
# Grouping:
#   [A] Platform pinning + deploy identity
#   [B] Domain + project identity
#   [C] Application database
#   [D] DB user passwords
#   [E] OAuth2 client secrets
#   [F] Google OAuth2
#   [G] Stripe (EU market)
#   [H] YooKassa / CloudPayments (RU market)
#   [I] SMTP
#   [J] Branding — company & logos
#   [K] Branding — light theme tokens
#   [L] Branding — dark theme tokens
#   [M] Maps
#   [N] Frontend build-args (webapp/driver/pay/landing)
#   [O] Backend runtime tunables

# ─── [A] Platform pinning + deploy identity ──────────────────────────

# Platform version. Must match an apostol-csms/* git tag (vX.Y.Z) and a
# pushed GHCR image (ghcr.io/apostol-csms/csms-backend:X.Y.Z). The
# canonical source is envs/<env>/platform.lock.json — install.sh
# re-exports PLATFORM_VERSION from there and asserts it matches.
PLATFORM_VERSION=

# Deployment environment selector (dev|stage|prod). Used by compose,
# the backend (exposed as `project.deployment`), and by per-env secret
# providers to pick the right vault namespace.
BUILD_ENV=dev

# ─── [B] Domain + project identity ───────────────────────────────────

# Compose project name (docker compose --project-name). Short, kebab-case,
# used to prefix container/network/volume names.
PROJECT_NAME=csms

# Brand code (short id used by frontend apps for URL slugs, asset paths,
# analytics segmentation). Often same as PROJECT_NAME.
BRAND=csms

# Primary domain — nginx serves landing/cloud/cpo/cs/admin/driver/pay/
# auth/api/ws/ocpp as subdomains of this. Must have 12 A-records resolving
# to this host before install.
DOMAIN=example.com

# Project identity seeded into postgres `project.*` GUCs (used by the
# backend/OCPI/OCPP layers) and exposed via `whoami` to the frontend.
PROJECT_ID=csms
PROJECT_CODE=csms
PROJECT_DISPLAY_NAME="Apostol CSMS"
PROJECT_URL=https://cloud.example.com
PROJECT_SCOPE_ALIAS=https://cloud.example.com
PROJECT_LOCALE=en
PROJECT_CURRENCY=EUR
PROJECT_COUNTRY_CODE=EU
PROJECT_PARTY_ID=CSM
PROJECT_PAYMENT_SYSTEM=stripe
PROJECT_SMS_ADDRESS=example.com
PROJECT_DESCRIPTION="Apostol CSMS — Charging Station Management System"
PROJECT_OCPP_API=http://ocpp:9220

# ─── [C] Application database ────────────────────────────────────────

PGDATABASE=csms
# Postgres superuser password (distinct from DB_PASS_KERNEL which is the
# schema-owner role).
POSTGRES_PASSWORD=CHANGE_ME

# ─── [D] DB user passwords ───────────────────────────────────────────
# Generate with e.g. `openssl rand -base64 24` per role.

DB_PASS_KERNEL=CHANGE_ME
DB_PASS_ADMIN=CHANGE_ME
DB_PASS_DAEMON=CHANGE_ME
DB_PASS_APIBOT=CHANGE_ME
DB_PASS_MAILBOT=CHANGE_ME
DB_PASS_OCPP=CHANGE_ME
DB_PASS_OCPI=CHANGE_ME
DB_PASS_HTTP=CHANGE_ME
DB_PASS_CPO=CHANGE_ME
DB_PASS_DRIVER=CHANGE_ME
DB_PASS_DEMO=demo

# ─── [E] OAuth2 client secrets ───────────────────────────────────────
# Generated at the backend on first install; copy from install output
# or rotate via `gh release` tooling.

OAUTH2_SECRET_SERVICE=CHANGE_ME
OAUTH2_SECRET_WEB=CHANGE_ME
OAUTH2_SECRET_ANDROID=CHANGE_ME
OAUTH2_SECRET_IOS=CHANGE_ME
OAUTH2_SECRET_OCPP=CHANGE_ME

# OAuth2 client_id + scope that the webapp/driver send with login.
# Must match an oauth2.audience row on the backend (created by
# install-time seeds, typically `web-<DOMAIN>`).
OAUTH_CLIENT_ID=
OAUTH_SCOPE=

# ─── [F] Google OAuth2 ───────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials.
# Optional — enable only if you need "Login with Google".

GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── [G] Stripe (EU market) ──────────────────────────────────────────
# https://dashboard.stripe.com/apikeys

STRIPE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── [H] YooKassa / CloudPayments (RU market) ────────────────────────
# Optional — enable one per brand.

YOOKASSA_SHOP_ID=
YOOKASSA_SHOP_KEY=

# ─── [I] SMTP ────────────────────────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME_INFO=info@example.com
SMTP_PASSWORD_INFO=CHANGE_ME
SMTP_USERNAME_NOREPLY=noreply@example.com
SMTP_PASSWORD_NOREPLY=CHANGE_ME
SMTP_USERNAME_SUPPORT=support@example.com
SMTP_PASSWORD_SUPPORT=CHANGE_ME

# Landing contact-form SMTP (Nuxt runtime envs — Nuxt picks up NUXT_*
# prefix). Defaults repeat the SMTP_* above if you want one-path SMTP.
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=noreply@example.com
NUXT_SMTP_PASS=CHANGE_ME
NUXT_SMTP_TO=info@example.com

# ─── [J] Branding — company & logos ──────────────────────────────────

BRANDING_LOGO_URL=/brand-defaults/logo.png
BRANDING_LOGO_DARK_URL=/brand-defaults/logo-white.png
BRANDING_FAVICON_URL=/brand-defaults/favicon.ico
BRANDING_SUPPORT_EMAIL=support@example.com

# ─── [K] Branding — light theme tokens ───────────────────────────────

BRANDING_LIGHT_PRIMARY_COLOR=#038FDE
BRANDING_LIGHT_ACCENT_COLOR=#5EB7ED
BRANDING_LIGHT_SUCCESS_COLOR=#52C41A
BRANDING_LIGHT_DANGER_COLOR=#F5222D
BRANDING_LIGHT_WARNING_COLOR=#FA8C15
BRANDING_LIGHT_INFO_COLOR=#1890FF
BRANDING_LIGHT_BG_COLOR=#FFFFFF
BRANDING_LIGHT_BG_ALT_COLOR=#F5F5F5
BRANDING_LIGHT_BG_MUTED_COLOR=#F6F8F9
BRANDING_LIGHT_SURFACE_COLOR=#FFFFFF
BRANDING_LIGHT_TEXT_COLOR=#545454
BRANDING_LIGHT_TEXT_MUTED_COLOR=#8E9194
BRANDING_LIGHT_BORDER_COLOR=#EEEFF0
BRANDING_LIGHT_BORDER_STRONG_COLOR=#D9D9D9
BRANDING_LIGHT_BORDER_TABLE_COLOR=#E9ECEF
BRANDING_LIGHT_SIDEBAR_COLOR=#003366
BRANDING_LIGHT_SIDEBAR_LOGO_COLOR=#002447
BRANDING_LIGHT_SUCCESS_BG_COLOR=#F6FFED
BRANDING_LIGHT_SUCCESS_BORDER_COLOR=#B7EB8F
BRANDING_LIGHT_DANGER_BG_COLOR=#FFF1F0
BRANDING_LIGHT_DANGER_BORDER_COLOR=#FFA39E
BRANDING_LIGHT_WARNING_BG_COLOR=#FFF7E6

# ─── [L] Branding — dark theme tokens ────────────────────────────────

BRANDING_DARK_PRIMARY_COLOR=#038FDE
BRANDING_DARK_ACCENT_COLOR=#5EB7ED
BRANDING_DARK_SUCCESS_COLOR=#52C41A
BRANDING_DARK_DANGER_COLOR=#F5222D
BRANDING_DARK_WARNING_COLOR=#FA8C15
BRANDING_DARK_INFO_COLOR=#1890FF
BRANDING_DARK_BG_COLOR=#38424B
BRANDING_DARK_BG_ALT_COLOR=#38424B
BRANDING_DARK_BG_MUTED_COLOR=#4b5761
BRANDING_DARK_SURFACE_COLOR=#4b5761
BRANDING_DARK_TEXT_COLOR=#E0E0E0
BRANDING_DARK_TEXT_MUTED_COLOR=#b8b8b8
BRANDING_DARK_BORDER_COLOR=#5a6670
BRANDING_DARK_BORDER_STRONG_COLOR=#6a747e
BRANDING_DARK_BORDER_TABLE_COLOR=#5a6670
BRANDING_DARK_SIDEBAR_COLOR=#0A2333
BRANDING_DARK_SIDEBAR_LOGO_COLOR=#071725
BRANDING_DARK_SUCCESS_BG_COLOR=#2a3a2a
