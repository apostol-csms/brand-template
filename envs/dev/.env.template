# envs/dev/.env.template
# Per-environment overrides for the `dev` deployment. Merged over the
# root .env.template by install.sh/update.sh. Only include values that
# differ from defaults.

BUILD_ENV=dev
DOMAIN=localhost

PROJECT_DISPLAY_NAME="Apostol CSMS (dev)"
PROJECT_URL=http://localhost

# Pre-release channel — dev follows alpha/rc tags.
# The canonical PLATFORM_VERSION lives in envs/dev/platform.lock.json;
# this line is a comment-only hint.
#
# Frontend build args (NEXT_PUBLIC_*, NUXT_*) — leave empty for localhost.
